spec main:
    show "--- Testing Pack Collections ---"
    
    show "1. Basic Pack"
    firm numbers = pack(1, 2, 3)
    show "Numbers: |numbers|"
    
    show "2. Mixed Types"
    firm mixed = pack("hello", 42, On)
    show "Mixed: |mixed|"
    
    show "3. Empty Pack"
    firm empty = pack()
    show "Empty: |empty|"
    
    show "4. Nested Expression"
    firm values = pack(10 + 5, 20 - 5, 30 * 2)
    show "Values: |values|"
    
    show "--- Pack Verification Complete ---"
done

main()
